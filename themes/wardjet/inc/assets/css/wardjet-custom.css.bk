    margin: auto;
    position: absolute;
    top: 0; left: 0; bottom: 0; right: 0;
    }*/

    #slider p.linea_texto_1 {
        font-weight: 300;
        font-family: 'Roboto', sans-serif;
        text-align: left;
        font-size: 4.62em;
    }
    #slider p.linea_texto_2 {
        font-family: 'Roboto', sans-serif;
        font-weight: 300;
        font-size: 1em;
        text-align: left;
    }
    #slider .cta {
        text-align: left;
    }
    .heading {
        font-size: 4.62em;
        font-family: 'Roboto', sans-serif;
        color: #003b71;
        text-align: center;
        font-weight: 300;
        line-height: 1em;
    }
    .mission h1.heading, .featured .heading {
        color: #000;
        text-align: left;
    }
    .featured p {
        font-size: 2em;
        line-height: 1.3em;
    }
    .mission p {
        color: #000;
        font-family: 'Roboto', sans-serif;
        font-weight: 300;
        font-size: 2em;
        padding-top: 0.5em;
        text-align: left;
    }

    .mission .carousel-indicators li {
        text-indent: 0;
        display: inline-block;
        padding: 21px 0;
        margin: 4px 0;
        width: 175px;
        background-color: transparent;
        font-family: 'Roboto', sans-serif;
        font-weight: 400;
        font-size: 1em;
        text-transform: uppercase;
    }

    .mission ol.carousel-indicators {
        top: 0;
        bottom: unset;
        margin-top: 7.5em;
    }
    .mission .carousel-inner {
        padding-top: 23em;
    }

    .mission .carousel-control-next, .mission .carousel-control-prev {
        top: 134px;
        align-items: baseline;
    }
    .mission .carousel-control-prev-icon {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='%23000' width='8' height='8' viewBox='0 0 8 8'%3e%3cpath d='M5.25 0l-4 4 4 4 1.5-1.5L4.25 4l2.5-2.5L5.25 0z'/%3e%3c/svg%3e")
    }
    .mission .carousel-control-next-icon {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='%23000' width='8' height='8' viewBox='0 0 8 8'%3e%3cpath d='M2.75 0l-1.5 1.5L3.75 4l-2.5 2.5L2.75 8l4-4-4-4z'/%3e%3c/svg%3e")
    }

    img.companypic {
        margin: 3em 0;
    }
    .company {
        border-bottom: solid 1px #707070;
        clear: both;
        padding-top: 5em;
        padding-bottom: 5em;
    }

.company .co_logo {
    text-align: center;
    /*margin-top: 7em;*/
}

.company p.cta {
    float: right;
    /*margin-top: 9em;
    margin-top: 6em;*/
}

   /* .review .container{
        padding: 6em 0;
        }*/
    h2.review {
        font-family: 'Roboto', sans-serif;
        font-weight: 300;
        font-size: 2em;
        width: 75%;
        margin: auto;
    }

        section.review .carousel-control-prev-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='%23000' width='8' height='8' viewBox='0 0 8 8'%3e%3cpath d='M5.25 0l-4 4 4 4 1.5-1.5L4.25 4l2.5-2.5L5.25 0z'/%3e%3c/svg%3e")
        }
        section.review .carousel-control-next-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='%23000' width='8' height='8' viewBox='0 0 8 8'%3e%3cpath d='M2.75 0l-1.5 1.5L3.75 4l-2.5 2.5L2.75 8l4-4-4-4z'/%3e%3c/svg%3e")
        }
        section.review .carousel-control-next, section.review .carousel-control-prev {
            top: 247px;
        }
        section.review p.name {
            font-size: 1.5em;
            margin-bottom: 0;
        }
        section.review p.position {
            font-size: 1.25em;
            text-transform: uppercase;
            margin-top: 0;
        }

        section.partnership {
            padding: 6em 0;
        }
        section.partnership h1.heading {
            font-size: 4.62em;
            font-family: 'Roboto', sans-serif;
            color: #003b71;
            text-align: left;
            font-weight: 300;
            line-height: 1em;
            border-top: solid 1px #003b71;
            padding-top: 0.9em;
            margin-top: 0.75em;
        }


        section.contact {
            background-color: #ebebeb;
            padding: 6em 0;
        }

        section.contact h2.heading {
            color: #003b71;
            font-size: 3em;
            text-align: left;
        }

        #page section.contact .cta a {
            background-color: #fff;
        }
        #page section.contact input[type=submit] {
            background-color: #fff;
            font-size: 1.17em;
        }
        section.contact p {
            font-size: 1.4em;
            line-height: 1.15em;
        }
        /* image map */


        .object-label {
            position: absolute;
            top: 40%;
            left: 50%;
            margin-left: 0px;
            border-radius: 51%;
            border: 8px solid #093c71;
            width: 8px;
            height: 8px;
            box-sizing: unset;
        }

        .object-label::after {
          position: absolute;
          content: '';
          width: 0px;
          height: 0px;
          bottom: -30px;
          left: -6px;
          border: 10px solid transparent;
          border-top: 17px solid #093c71;
      }
      .object-label:hover {
        border: 10px solid #00b2e3;
        margin-left: -2px;
    }

    .object-label:hover:after {
      border-top: 17px solid #00b2e3;
      bottom: -33px;
  }
  .object-info {
    position: absolute;
    display: none;
    z-index: 1;
    left: 55px;
    bottom: -90px;
    width: 14.4em;
    margin-left: 0em;
    padding: 1em;
    border: 0;
    background-color: rgba(255,255,255,1);
    border-radius: 4px;
    -webkit-box-shadow: none;
    box-shadow: none;
    box-shadow: 0 0 0 2px rgb(255 255 255), 0.3em 0.3em 1em rgb(0 0 0 / 30%);
}


.object-content p {
    color: #a0a2a5;
    font-size: 0.75em;
}
.object-content strong {
    text-transform: uppercase;
}




#about section.about {
    background-color: #000;
    padding: 10em 0;
}
#about section.about h1.heading{
    /*color: #000;*/
}
#about section.about p{
    color: #003b71;
    font-size: 2em;
}
.mission {
    background-color: #000;
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center center;
}
#about section.ourmission {
    background-color: #fff;
    padding: 10em 0;
}
#about section.ourmission .heading {
    color: #000;
    border-bottom: 1px solid #000;
    border-top: 1px solid #000;
    padding: 1em 0;
    margin: 1.5em 0;
}
#about section.ourmission p {
    font-size: 2em;
}
#about section.ourmission ol.carousel-indicators {
    top: 0;
    bottom: unset;
    margin-top: 2em;
}
#about section.ourmission ol.carousel-indicators li {
    text-indent: unset;
    margin: 0px 0px;
    padding: 0px;
    display: block;
    width: 140px;
    text-align: center;
    font-size: 1em;
    font-weight: 800;
    letter-spacing: 2px;
    min-width: 150px;
}
#about section.ourmission ol.carousel-indicators li {
    text-indent: unset;
    margin: 0px 12px;
    padding: 4px;
    display: block;
    width: 300px;
    text-align: center;
}

#about section.ourmission .carousel-control-next, #about section.ourmission .carousel-control-prev {
