    margin-bottom: 0;
    color:  #fff;    
}


.full-width-gallery .carousel-item{
    width: 100%;
    padding-top: 45%;
    background-repeat: no-repeat;
    background-size: contain;
    background-position: center center;
}

.top-border {
    border-top: 1px solid #003b71;
}

.bottom-border {
    border-bottom: 1px solid #003b71;
}
.top-bottom-border{
    border-top: 1px solid #003b71;
    border-bottom: 1px solid #003b71;
}


.sub-title {
