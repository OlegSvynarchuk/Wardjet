#page .cta button, #page .cta a, #page input[type=submit] {
    background-color: transparent;
    text-decoration: none;
    -webkit-appearance: none;
    border: solid 1px #00b2e3;
    -webkit-box-shadow: none;
    box-shadow: none;
    cursor: pointer;
    padding: 0;
    margin: 0;
    display: inline-block;
    color: #003b71;
    padding: 0.65em 0.85em 0.65em 0.85em;
    -webkit-transition: all 0.25s ease-in-out;
    transition: all 0.25s ease-in-out;
    cursor: pointer;
    display: -webkit-box;
    display: -ms-flexbox;
    display: inline-block;
    -webkit-box-align: center;
    -ms-flex-align: center;
    align-items: center;
    -webkit-box-pack: center;
    -ms-flex-pack: center;
    justify-content: center;
    line-height: 1;
    font-style: normal;
    font-weight: 400;
    font-size: 1em;
    border-radius: 4px;
    /* font-family: "roc-grotesk-wide"; */
    margin-top: 0.75em;
    font-family: 'Roboto', sans-serif;
    color: #00b2e3;
    text-transform: uppercase;
}
#page .cta, #page .cta{
    font-size: 1.2em;
}


.products-listing .wrapper {
    padding: 0em 0;
}

h3.product_category {
    font-size: 1.7em;
    font-family: 'Roboto', sans-serif;
    color: #003b71;
    text-align: center;
    font-weight: 300;
    line-height: 1em;
    border-top: solid 1px #003b71;
    padding-top: 0.75em;
    padding-bottom: 2em;
    text-transform: uppercase;
}

.content-text {
    padding: 0 6em;
}
.content-text .title {
    font-size: 3em;
    font-family: 'Roboto', sans-serif;
    color: #003b71;
    text-align: left;
    font-weight: 300;
    line-height: 1em;
}
.content-text p {
    font-weight: 700;
    font-size: 1.5em;
}

.col-lg-12 > .content-image {
    flex: 0 0 41.666667%;
    max-width: 41.666667%;
}
.col-lg-12 > .content-text {
    flex: 0 0 58.333333%;
    max-width: 58.333333%;
    padding: 0 1em;
}

section.products-listing {
    padding: 2em 0;
}
section.filter {
    background-color: #e9e9e9;
    padding: 6em 0;
}


section.filter .sorter .title {
    font-size: 1.4em;
    font-family: 'Roboto', sans-serif;
    color: #003b71;
    text-align: left;
    font-weight: 700;
    line-height: 1em;
    text-transform: uppercase;
}

.custom-select[multiple], .custom-select[size]:not([size="1"]) {
    border: solid 1px #000;
}
.custom-select option {
    font-size: 1.4em;
    font-family: 'Roboto', sans-serif;
    color: #003b71;
    font-weight: 500;
    padding: 0.5em 0.75em;
}
.custom-select option:checked {
    border-radius: 10px;
    background: rgb(9, 60, 113) linear-gradient(
        0deg
        , rgb(9, 60, 113) 0%, rgb(9, 60, 113) 100%);
    background: rgb(210, 210, 210) linear-gradient(
        0deg
        , rgb(210, 210, 210) 0%, rgb(210, 210, 210) 100%);    
    color: #fff !important;
}

.custom-select option:active {
    border-radius: 10px;
    background: rgb(200, 200, 200) linear-gradient(
        0deg
        , rgb(200, 200, 200) 0%, rgb(200, 200, 200) 100%);
    color: #fff;
}

.custom-select .product-name {
    padding-left: 2em;
}

h3.sorter-title {
    font-size: 1.25em;
    font-family: 'Roboto', sans-serif;
    color: #003b71;
    font-weight: 500;
    border-top: solid 1px #003b71;
    padding-top: 0.75em;
    padding-bottom: 2em;
    margin-top: 6em;
    text-transform: uppercase;
}

.filter .slick-prev:before {
    content: ' ';
    background-image: url(../img/left.svg);
    width: 100%;
    height: 100%;
    display: block;
    background-repeat: no-repeat;
}
.filter .slick-next:before {
    content: ' ';
    background-image: url(../img/right.svg);
    width: 100%;
    height: 100%;
    display: block;
    background-repeat: no-repeat;
}
.filter .slick-prev {
    left: 100px;
    top: 106%;
    width: 102px;
    height: 47px;
    z-index: 100;
}
.filter .slick-next {
    left: 275px;
    top: 106%;
    width: 102px;
    height: 47px;
    z-index: 100;
}
.filter p.pagingInfo {
    padding-left: 9.75em;
    z-index: 50;
}
.content-text p.phrase {
    font-size: 1.75em;
    font-weight: 100;
    text-transform: uppercase;
}
.content-text p.description {
    font-size: 1.6em;
    font-weight: 100;
}

#page #sorter-btn button,
#page .filter .cta a {
    background-color: #fff;
}




.carousel-v2 .carousel-control-next-icon {
    background-image: url(../img/right.svg);
    width: 100%;
}
.carousel-v2 .carousel-control-prev-icon {
    background-image: url(../img/left.svg);
    width: 100%;
}


